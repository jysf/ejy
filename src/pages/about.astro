---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection, render } from 'astro:content';
import { asset } from '../utils';

const aboutData = await getCollection('about');
const about = aboutData[0];
const { Content } = await render(about);

const siteData = await getCollection('site');
const site = siteData[0]?.data;

const allProjects = await getCollection('projects');
const recentProjects = allProjects
  .filter((p) => p.id !== 'the-triangle')
  .sort((a, b) => b.data.order - a.data.order)
  .slice(0, 3);
---

<BaseLayout title="About — Emma Yashinsky" description="Learn more about Emma Yashinsky, a graphic designer studying at Drexel University.">
  <section class="about-hero">
    <div class="about-grid">
      {about.data.image && (
        <div class="about-image">
          <img src={asset(about.data.image)} alt="Emma Yashinsky" />
        </div>
      )}
      <div class="about-content">
        <h1 class="about-heading">{about.data.heading}</h1>
        <div class="about-bio">
          <Content />
        </div>
      </div>
    </div>
  </section>

  {site && (
    <section class="about-contact">
      <div class="container">
        <h2>I would love to hear from you at:</h2>
        <a class="email-link" href={`mailto:${site.email}`}>{site.email}</a>
        <div class="about-social">
          <a class="social-link" href={site.instagram} target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a class="social-link" href={site.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <section class="recent-works">
    <div class="container-wide">
      <h1 class="section-heading">Recent Works</h1>
      <div class="recent-list">
        {recentProjects.map((project) => (
          <a href={asset(`/projects/${project.id}`)} class="recent-card reveal">
            <div class="recent-card__image">
              <img src={asset(project.data.images[0] || '/images/placeholder.jpg')} alt={project.data.title} loading="lazy" />
            </div>
            <div class="recent-card__info">
              <h3 class="recent-card__title">{project.data.title}</h3>
              <h4 class="recent-card__date">{project.data.date}</h4>
              <p class="recent-card__tags">{project.data.tags.join(' — ')}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="works-cta">
        <a href={asset('/projects')} class="button">View More Work</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    padding-top: var(--nav-height);
    background: #c9a96e;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: start;
  }

  .about-image {
    height: 100%;
  }

  .about-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-content {
    padding: var(--space-xl) var(--space-xl) var(--space-xl) var(--space-lg);
  }

  .about-heading {
    margin-bottom: var(--space-lg);
  }

  .about-bio {
    font-size: 16px;
    line-height: 1.8;
  }

  .about-contact {
    text-align: center;
    padding: var(--space-2xl) 0;
  }

  .about-contact h2 {
    margin-bottom: var(--space-md);
    color: var(--midnight-blue);
    font-weight: 700;
  }

  .about-social {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    margin-top: var(--space-md);
    color: var(--midnight-blue);
  }

  .recent-works {
    padding: var(--space-2xl) 0;
  }

  .section-heading {
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  .recent-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .recent-card {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: var(--space-lg);
    align-items: center;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .recent-card:hover {
    color: var(--burnt-orange);
  }

  .recent-card__image img {
    width: 100%;
    display: block;
    border-radius: 2px;
  }

  .recent-card__info {
    color: var(--deep-charcoal);
    transition: color var(--transition-fast);
  }

  .recent-card:hover .recent-card__info {
    color: var(--burnt-orange);
  }

  .recent-card__title {
    margin-bottom: 4px;
  }

  .recent-card__date {
    margin-bottom: 4px;
    font-weight: 300;
  }

  .recent-card__tags {
    font-size: 13px;
    opacity: 0.7;
  }

  .works-cta {
    text-align: center;
    margin-top: var(--space-xl);
  }

  @media (max-width: 767px) {
    .about-grid {
      grid-template-columns: 1fr;
    }

    .about-content {
      padding: var(--space-lg) var(--space-md);
    }

    .recent-card {
      grid-template-columns: 1fr;
    }
  }
</style>
